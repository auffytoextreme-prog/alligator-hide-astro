---
import logoColor from '@/assets/logo-alligatorhide.png';
import logoWhite from '@/assets/logo-white.png';

const navigation = [
  { name: 'Inicio', href: '/' },
  { name: 'Tecnología', href: '/tecnologia' },
  { name: 'Galería', href: '/galeria' },
  { name: 'Quiénes Somos', href: '/quienes-somos' },
  { name: 'Contacto', href: '/contacto' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-[padding,background-color,box-shadow] duration-300 bg-transparent backdrop-blur-[2px] py-5"
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0 transition-all duration-300">
        <img
          id="logo-white"
          src={logoWhite.src}
          alt="AlligatorHide"
          class="w-auto h-10 md:h-[3.15rem] transition-all duration-300"
        />
        <img
          id="logo-color"
          src={logoColor.src}
          alt="AlligatorHide"
          class="w-auto h-9 md:h-11 transition-all duration-300 hidden"
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-8">
        {navigation.map((item) => (
          <a
            href={item.href}
            class:list={[
              'nav-link text-sm font-medium uppercase tracking-wide transition-colors duration-200 link-underline',
              currentPath === item.href
                ? 'text-primary-foreground nav-active'
                : 'text-primary-foreground/80 hover:text-primary-foreground',
            ]}
          >
            {item.name}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-3 text-primary-foreground"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <svg id="icon-menu" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Side Panel -->
<div
  id="mobile-menu"
  class="fixed top-0 right-0 h-full w-72 bg-secondary z-[60] transform translate-x-full transition-transform duration-300 ease-in-out lg:hidden"
>
  <div class="flex justify-end p-5">
    <button id="mobile-menu-close" class="p-3 text-white/70 hover:text-white transition-colors" aria-label="Cerrar menú">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  <nav class="flex flex-col px-6 gap-1">
    {navigation.map((item) => (
      <a
        href={item.href}
        class:list={[
          'mobile-nav-link text-base font-medium uppercase tracking-wide py-4 px-4 text-right rounded-lg transition-colors duration-200',
          currentPath === item.href
            ? 'text-primary bg-white/5'
            : 'text-white/60 hover:text-white hover:bg-white/5',
        ]}
      >
        {item.name}
      </a>
    ))}
  </nav>
</div>

<!-- Mobile menu overlay -->
<div id="mobile-overlay" class="fixed inset-0 z-[55] bg-black/50 backdrop-blur-sm lg:hidden hidden transition-opacity"></div>

<script is:inline>
(function() {
  var header = document.getElementById('site-header');
  var btn = document.getElementById('mobile-menu-btn');
  var menu = document.getElementById('mobile-menu');
  var closeBtn = document.getElementById('mobile-menu-close');
  var overlay = document.getElementById('mobile-overlay');
  var logoWhite = document.getElementById('logo-white');
  var logoColor = document.getElementById('logo-color');
  var isOpen = false;
  var isScrolled = false;

  function isMobile() {
    return window.innerWidth < 1024;
  }

  function updateHeader() {
    var scrolled = window.scrollY > 20;
    if (scrolled === isScrolled) return;
    isScrolled = scrolled;

    if (scrolled) {
      header.classList.remove('bg-transparent', 'backdrop-blur-[2px]', 'py-5');
      header.classList.add('bg-background/95', 'backdrop-blur-xl', 'shadow-sm', 'border-b', 'border-foreground/[0.06]', 'py-2');

      if (!isMobile()) {
        logoWhite.classList.add('hidden');
        logoColor.classList.remove('hidden');
      }

      btn.classList.remove('text-primary-foreground');
      btn.classList.add('text-foreground');
      document.querySelectorAll('.nav-link').forEach(function(el) {
        if (el.classList.contains('nav-active')) {
          el.classList.remove('text-primary-foreground');
          el.classList.add('text-primary');
        } else {
          el.classList.remove('text-primary-foreground/80', 'hover:text-primary-foreground');
          el.classList.add('text-secondary', 'hover:text-primary');
        }
      });
    } else {
      header.classList.add('bg-transparent', 'backdrop-blur-[2px]', 'py-5');
      header.classList.remove('bg-background/95', 'backdrop-blur-xl', 'shadow-sm', 'border-b', 'border-foreground/[0.06]', 'py-2');
      logoWhite.classList.remove('hidden');
      logoColor.classList.add('hidden');
      btn.classList.add('text-primary-foreground');
      btn.classList.remove('text-foreground');
      document.querySelectorAll('.nav-link').forEach(function(el) {
        if (el.classList.contains('nav-active')) {
          el.classList.add('text-primary-foreground');
          el.classList.remove('text-primary');
        } else {
          el.classList.add('text-primary-foreground/80', 'hover:text-primary-foreground');
          el.classList.remove('text-secondary', 'hover:text-primary');
        }
      });
    }
  }

  function openMenu() {
    isOpen = true;
    menu.classList.remove('translate-x-full');
    menu.classList.add('translate-x-0');
    overlay.classList.remove('hidden');
    btn.setAttribute('aria-expanded', 'true');
    btn.setAttribute('aria-label', 'Cerrar menú');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    isOpen = false;
    menu.classList.add('translate-x-full');
    menu.classList.remove('translate-x-0');
    overlay.classList.add('hidden');
    btn.setAttribute('aria-expanded', 'false');
    btn.setAttribute('aria-label', 'Abrir menú');
    document.body.style.overflow = '';
  }

  function toggleMenu() {
    if (isOpen) closeMenu();
    else openMenu();
  }

  btn.addEventListener('click', toggleMenu);
  closeBtn.addEventListener('click', closeMenu);
  overlay.addEventListener('click', closeMenu);

  menu.querySelectorAll('a').forEach(function(link) {
    link.addEventListener('click', function() {
      if (isOpen) closeMenu();
    });
  });

  window.addEventListener('resize', function() {
    if (!isMobile() && isOpen) closeMenu();
    updateHeader();
  });

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();
})();
</script>
