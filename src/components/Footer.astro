---
import logoDark from '@/assets/logo-alligatorhide.png';
import logoWhite from '@/assets/logo-white.png';
const currentYear = new Date().getFullYear();
---

<footer class="bg-background text-foreground relative">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-10">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">

      <!-- Contacto -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4 text-foreground">Contacto</h3>
        <ul class="space-y-3">
          <li>
            <a href="tel:+59899229981" class="flex items-start gap-3 text-muted-foreground hover:text-foreground transition-colors text-sm group">
              <svg class="w-5 h-5 lg:w-4 lg:h-4 mt-0.5 flex-shrink-0 group-hover:text-primary transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              +598 99 229 981
            </a>
          </li>
          <li>
            <a href="mailto:info@alligatorhideuy.com" class="flex items-start gap-3 text-muted-foreground hover:text-foreground transition-colors text-sm group">
              <svg class="w-5 h-5 lg:w-4 lg:h-4 mt-0.5 flex-shrink-0 group-hover:text-primary transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              info@alligatorhideuy.com
            </a>
          </li>
          <li>
            <div class="flex items-start gap-3 text-muted-foreground text-sm">
              <svg class="w-5 h-5 lg:w-4 lg:h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              José Enrique Rodó 2082, Montevideo
            </div>
          </li>
          <li>
            <a href="https://instagram.com/alligatorhide" target="_blank" rel="noopener noreferrer" class="flex items-start gap-3 text-muted-foreground hover:text-foreground transition-colors text-sm group">
              <svg class="w-5 h-5 lg:w-4 lg:h-4 mt-0.5 flex-shrink-0 group-hover:text-primary transition-colors duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" />
                <circle cx="12" cy="12" r="5" />
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
              </svg>
              Síganos en Instagram
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider mb-4 text-foreground">Legal</h3>
        <ul class="space-y-2">
          <li>
            <a href="/terminos-y-condiciones" class="text-muted-foreground hover:text-foreground transition-colors text-sm">
              Términos y Condiciones
            </a>
          </li>
          <li>
            <a href="/politica-de-privacidad" class="text-muted-foreground hover:text-foreground transition-colors text-sm">
              Política de Privacidad
            </a>
          </li>
        </ul>
      </div>

      <!-- Brand -->
      <div class="lg:col-span-1 flex flex-col items-end text-right">
        <a href="/">
          <img src={logoDark.src} alt="AlligatorHide" class="h-10 w-auto mb-4 hover:opacity-70 transition-opacity lg:hidden" />
          <img src={logoDark.src} alt="AlligatorHide" class="h-10 w-auto mb-4 hover:opacity-70 transition-opacity hidden lg:block" />
        </a>
        <p class="text-muted-foreground text-sm leading-relaxed mb-4">
          Impermeabilización definitiva con tecnología americana. Garantía escrita de hasta 18 años.
        </p>
      </div>

    </div>

    <!-- Bottom -->
    <div class="mt-6 pt-4 relative">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-foreground/10 to-transparent"></div>
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-muted-foreground text-sm">
          &copy; {currentYear} AlligatorHide Uruguay. Todos los derechos reservados.
        </p>
        <p class="text-muted-foreground text-sm">
          Sistema importado de EE.UU. · Garantía hasta 18 años
        </p>
      </div>
    </div>
  </div>
</footer>
