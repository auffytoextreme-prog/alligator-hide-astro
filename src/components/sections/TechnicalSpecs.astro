---
---

<section class="section-padding bg-muted">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Content -->
      <div>
        <span class="inline-block text-primary text-sm font-semibold uppercase tracking-wider mb-4">
          Especificaciones técnicas
        </span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-foreground mb-6">
          Prueba técnica en lenguaje simple
        </h2>
        <p class="text-muted-foreground text-lg mb-8 leading-relaxed">
          Nuestro sistema combina tecnología avanzada con facilidad de aplicación. Una fórmula diseñada para ofrecer máximo rendimiento sin comprometer la seguridad ni el medio ambiente.
        </p>
        <a href="/productos" class="inline-flex items-center justify-center bg-primary text-primary-foreground px-6 py-3 rounded-lg font-medium shadow-md hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
          Ver especificaciones completas
        </a>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
        <div class="bg-card rounded-xl p-5 shadow-sm border border-border/50 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
          </div>
          <h4 class="font-semibold text-foreground text-sm mb-1">Base agua</h4>
          <p class="text-muted-foreground text-xs">Fórmula ecológica, no tóxica</p>
        </div>
        <div class="bg-card rounded-xl p-5 shadow-sm border border-border/50 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.59 4.59A2 2 0 1112 2a2 2 0 01.41.04M12 14v7m-3-3h6" /></svg>
          </div>
          <h4 class="font-semibold text-foreground text-sm mb-1">Libre de solventes</h4>
          <p class="text-muted-foreground text-xs">Sin disolventes nocivos</p>
        </div>
        <div class="bg-card rounded-xl p-5 shadow-sm border border-border/50 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
          </div>
          <h4 class="font-semibold text-foreground text-sm mb-1">Superficies húmedas</h4>
          <p class="text-muted-foreground text-xs">Aplicación incluso con humedad</p>
        </div>
        <div class="bg-card rounded-xl p-5 shadow-sm border border-border/50 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
          </div>
          <h4 class="font-semibold text-foreground text-sm mb-1">Secado rápido</h4>
          <p class="text-muted-foreground text-xs">Menor tiempo de obra</p>
        </div>
        <div class="bg-card rounded-xl p-5 shadow-sm border border-border/50 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>
          </div>
          <h4 class="font-semibold text-foreground text-sm mb-1">Puenteo de grietas</h4>
          <p class="text-muted-foreground text-xs">Alta flexibilidad del recubrimiento</p>
        </div>
        <div class="bg-card rounded-xl p-5 shadow-sm border border-border/50 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" /><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" /></svg>
          </div>
          <h4 class="font-semibold text-foreground text-sm mb-1">No inflamable</h4>
          <p class="text-muted-foreground text-xs">Bajo COV, seguro</p>
        </div>
      </div>
    </div>
  </div>
</section>
