---
const testimonials = [
  {
    name: 'Carlos M.',
    location: 'Pocitos, Montevideo',
    rating: 5,
    text: 'Llevaba años con problemas de filtraciones en el techo. Desde que aplicaron AlligatorHide, ni una gota de agua. La garantía por escrito da mucha tranquilidad.',
    surface: 'Terraza residencial',
  },
  {
    name: 'Edificio Portones',
    location: 'Ciudad Vieja, Montevideo',
    rating: 5,
    text: 'Gestionamos la impermeabilización de tres edificios del condominio. El resultado superó las expectativas y el seguimiento técnico post-aplicación es excelente.',
    surface: 'Cubierta industrial',
  },
  {
    name: 'Roberto A.',
    location: 'Punta Carretas, Montevideo',
    rating: 5,
    text: 'Después de probar otras soluciones que duraron poco, AlligatorHide fue diferente. El diagnóstico gratuito fue muy profesional y el presupuesto claro desde el inicio.',
    surface: 'Balcón y azotea',
  },
];
---

<section class="section-padding bg-background">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 scroll-animate">
      <span class="inline-block text-primary text-sm font-semibold uppercase tracking-wider mb-4">
        Clientes
      </span>
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground">
        Proyectos que hablan por sí solos
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10 max-w-5xl mx-auto">
      {testimonials.map((t, index) => (
        <div class={`bg-card border border-border/50 rounded-2xl p-6 sm:p-8 lg:p-10 shadow-md relative scroll-animate delay-${(index + 1) * 100}`}>
          <!-- Quote icon -->
          <svg class="w-8 h-8 text-primary/20 absolute top-8 right-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" /></svg>

          <!-- Avatar -->
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mb-6">
            <span class="text-primary font-display font-bold text-lg">{t.name.charAt(0)}</span>
          </div>

          <!-- Stars -->
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg class={`w-4 h-4 ${i < t.rating ? 'fill-primary text-primary' : 'text-muted'}`} viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
            ))}
          </div>

          <p class="text-foreground/80 mt-5 mb-8 leading-relaxed text-sm">
            "{t.text}"
          </p>

          <div class="border-t border-border/50 pt-5">
            <p class="font-semibold text-foreground text-sm">{t.name}</p>
            <p class="text-muted-foreground text-xs mt-1">{t.location} · {t.surface}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
