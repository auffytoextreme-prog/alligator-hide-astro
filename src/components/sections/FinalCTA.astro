---
const WHATSAPP_URL = 'https://wa.me/59899229981?text=Hola%2C%20quiero%20consultar%20sobre%20impermeabilizaci%C3%B3n%20de%20mi%20techo';
---

<section class="section-padding relative overflow-hidden bg-muted">
  <!-- Top curve transition from ForWho (dark background) -->
  <div class="absolute top-0 left-0 right-0 pointer-events-none z-10 leading-none">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-10 lg:h-14 block">
      <path d="M0,30 C360,60 1080,0 1440,30 L1440,0 L0,0 Z" fill="hsl(0 0% 11%)" />
    </svg>
  </div>

  <!-- Decorative background elements -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-gradient-to-b from-primary/5 via-transparent to-primary/[0.03]"></div>
    <div class="absolute -top-24 left-1/4 w-96 h-96 bg-primary/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 right-1/4 w-64 h-64 bg-[#4CBFA6]/10 rounded-full blur-[100px]"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-4xl mx-auto text-center scroll-animate">
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground mb-8 leading-[1.1] tracking-tight">
        La última impermeabilización que <br class="hidden sm:block" />
        va a necesitar.
      </h2>

      <p class="text-muted-foreground text-lg md:text-xl mb-12 max-w-2xl mx-auto leading-relaxed">
        Unimos tecnología de vanguardia y mano de obra experta para dar a su propiedad el blindaje que merece.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6 mb-16">
        <a
          href="/contacto"
          class="group relative overflow-hidden inline-flex items-center justify-center rounded-full px-10 py-4 text-lg font-medium bg-primary text-primary-foreground shadow-lg transition-all duration-500 hover:scale-105 hover:shadow-xl"
        >
          <!-- Calendar icon -->
          <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
          <span class="relative z-10">Agendar Diagnóstico</span>
          <!-- Arrow icon -->
          <svg class="ml-2 h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-in-out"></div>
        </a>

        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center justify-center rounded-full px-10 py-4 text-lg font-medium border-2 border-primary text-primary bg-transparent hover:bg-primary hover:text-primary-foreground transition-all duration-300"
        >
          <!-- WhatsApp / MessageCircle icon -->
          <svg class="mr-2 h-5 w-5 text-[#25D366]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z" /></svg>
          Contactar por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>
