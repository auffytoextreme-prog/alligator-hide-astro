---
const WHATSAPP_URL = 'https://wa.me/59899229981?text=Hola%2C%20quiero%20consultar%20sobre%20impermeabilizaci%C3%B3n%20de%20mi%20techo';
---

<section class="pt-16 md:pt-20 lg:pt-24 pb-24 md:pb-32 lg:pb-40 relative overflow-hidden bg-secondary">
  <!-- Top curve transition from ForWho (dark background) -->
  <div class="absolute top-0 left-0 right-0 pointer-events-none z-10 leading-none -mt-1">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-10 lg:h-14 block">
      <path d="M0,30 C360,60 1080,0 1440,30 L1440,0 L0,0 Z" fill="hsl(0 0% 11%)" />
    </svg>
  </div>

  <!-- Decorative background elements -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-gradient-to-b from-white/[0.03] via-transparent to-transparent"></div>
    <div class="absolute -top-24 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 right-1/4 w-64 h-64 bg-[#4CBFA6]/10 rounded-full blur-[100px]"></div>
    <div class="pattern-crocodile absolute inset-0 opacity-[0.03]"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-4xl mx-auto text-center scroll-animate">
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-8 leading-[1.1] tracking-tight">
        La última impermeabilización que <br class="hidden sm:block" />
        va a necesitar.
      </h2>

      <p class="text-white/60 text-lg md:text-xl mb-12 max-w-2xl mx-auto leading-relaxed">
        Unimos tecnología de vanguardia y mano de obra experta para dar a su propiedad el blindaje que merece.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6 mb-16">
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative overflow-hidden rounded-md shadow-lg hover:shadow-[#25D366]/30 transition-all duration-500 bg-[#25D366] text-white px-6 py-3 text-base font-medium tracking-wide uppercase inline-flex items-center justify-center"
        >
          <svg class="mr-2 h-5 w-5 relative z-10" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span class="relative z-10">Contactar por WhatsApp</span>
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/15 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-in-out"></div>
        </a>

        <a
          href="/contacto"
          class="group rounded-md border border-white/20 hover:border-white/40 backdrop-blur-sm transition-all duration-300 bg-white/10 hover:bg-white/15 text-white px-6 py-3 text-base font-medium tracking-wide uppercase inline-flex items-center justify-center"
        >
          Agendar Diagnóstico
          <svg class="ml-2 h-4 w-4 opacity-60 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
      </div>
    </div>
  </div>

</section>
