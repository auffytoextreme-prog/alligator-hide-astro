---
import VideoPlayer from '../react/VideoPlayer';
---

<section class="bg-secondary relative overflow-hidden">
  <!-- Top wave from HowWeWork (muted) -->
  <div class="absolute top-0 left-0 right-0 pointer-events-none z-10 leading-none -mt-1">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-10 lg:h-14 block">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,0 L0,0 Z" fill="hsl(40 10% 93%)" />
    </svg>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
    <div class="max-w-4xl mx-auto scroll-animate">
      <div class="mb-4">
        <h3 class="text-white font-semibold text-base sm:text-lg">
          Impermeabilización de 130 metros cuadrados en Centro, Montevideo
        </h3>
      </div>

      <VideoPlayer client:visible src="https://mczmhf2ntdcynbdr.public.blob.vercel-storage.com/video-demo.mp4" />

      <!-- Button below video -->
      <div class="mt-4 flex justify-end">
        <a
          href="/galeria"
          class="flex items-center gap-2 border border-white/30 hover:border-white/60 text-white/70 hover:text-white text-xs font-medium tracking-widest uppercase px-5 py-2.5 rounded-md transition-all duration-300 whitespace-nowrap"
        >
          Ver más proyectos
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg>
        </a>
      </div>
    </div>
  </div>
</section>
