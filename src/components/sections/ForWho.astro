---
const WHATSAPP_URL = 'https://wa.me/59899229981?text=Hola%2C%20quiero%20consultar%20sobre%20impermeabilizaci%C3%B3n%20de%20mi%20techo';

const audiences = [
  {
    id: 'residencias',
    title: 'Casas y Residencias',
    description: 'Solucione definitivamente goteras, humedad o moho. Proteja el valor de su hogar con una impermeabilización de calidad y sin obra húmeda.',
    features: ['Diagnóstico sin costo', 'Garantía extendida 18 años', 'Cero escombros'],
    color: 'from-[#4CBFA6]/20 to-transparent',
  },
  {
    id: 'corporativo',
    title: 'Edificios',
    description: 'Soluciones duraderas para consorcios y administraciones que buscan resolver filtraciones en azoteas sin mantenimiento constante y con total trazabilidad.',
    features: ['Documentación técnica', 'Trabajo rápido', 'Respaldo técnico'],
    color: 'from-[#2F8EAF]/20 to-transparent',
  },
  {
    id: 'industrial',
    title: 'Galpones Industriales',
    description: 'Ideales para centros logísticos y fábricas. Aísle el interior, proteja la mercadería y reduzca la temperatura drásticamente mejorando el clima laboral.',
    features: ['Alta reflectividad térmica', 'Sellado perimetral de chapas', 'Garantía 18 años'],
    color: 'from-[#3DAF8E]/20 to-transparent',
  },
  {
    id: 'hoteles',
    title: 'Hoteles',
    description: 'Maximice el confort de sus huéspedes. Al eliminar el calor excesivo del techo, reduce fuertemente sus costos fijos mensuales en climatización.',
    features: ['Gran ahorro energético', 'Sin interrupción de servicio', 'Factibilidad técnica'],
    color: 'from-[#5BC4E0]/20 to-transparent',
  },
];
---

<section class="py-16 lg:py-20 bg-secondary relative overflow-hidden">
  <!-- Decorative Background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-gradient-to-b from-primary/10 via-transparent to-primary/5"></div>
    <div class="absolute -top-24 right-1/4 w-96 h-96 bg-[#4CBFA6]/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-1/4 w-64 h-64 bg-[#4CBFA6]/10 rounded-full blur-[100px]"></div>
    <div class="pattern-crocodile absolute inset-0 opacity-[0.03]"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- ForWho Header -->
    <div class="text-center mb-10 scroll-animate">
      <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-5 leading-[1.1] tracking-tight">
        ¿Para quién es?
      </h2>
      <div class="h-1 w-16 bg-primary mx-auto mb-5 rounded-full"></div>
      <p class="text-white/60 max-w-2xl mx-auto text-lg leading-relaxed">
        Nuestra tecnología se adapta a diferentes escalas, garantizando la reflectancia solar y sellado absoluto contra la humedad.
      </p>
    </div>

    <!-- Tabs + Panels -->
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-5 lg:gap-8 scroll-animate delay-200">

      <!-- Left Side: Interactive Navigation -->
      <div class="lg:col-span-5 flex flex-col space-y-1.5" id="forwho-tabs" role="tablist">
        {audiences.map((audience, i) => (
          <button
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`forwho-panel-${audience.id}`}
            data-forwho-tab={audience.id}
            class={`group flex items-center gap-3 w-full text-left px-4 py-3 rounded-xl transition-all duration-500 ease-out border ${
              i === 0
                ? 'bg-white/10 border-white/15 shadow-sm'
                : 'bg-transparent border-transparent hover:bg-white/5'
            }`}
          >
            <h3 class={`font-display text-base font-semibold transition-colors duration-500 ${
              i === 0 ? 'text-white' : 'text-white/50 group-hover:text-white/80'
            }`}>
              {audience.title}
            </h3>
            <svg
              class={`w-4 h-4 ml-auto text-primary ${i === 0 ? '' : 'hidden'}`}
              data-forwho-arrow
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
            </svg>
          </button>
        ))}
      </div>

      <!-- Right Side: Dynamic Content Display -->
      <div class="lg:col-span-7 relative">
        {audiences.map((audience, i) => (
          <div
            id={`forwho-panel-${audience.id}`}
            role="tabpanel"
            data-forwho-panel={audience.id}
            class={`relative h-full w-full bg-white/5 rounded-2xl p-5 sm:p-6 overflow-hidden border border-white/10 min-h-[260px] ${
              i === 0 ? '' : 'hidden'
            }`}
          >
            <div class={`absolute inset-0 bg-gradient-to-br ${audience.color} opacity-30 pointer-events-none`}></div>

            <div class="relative z-10 animate-fade-up">
              <h3 class="font-display text-xl sm:text-2xl font-bold text-white mb-3 leading-[1.1]">
                {audience.title}
              </h3>

              <p class="text-white/60 text-sm sm:text-base mb-5 leading-relaxed max-w-xl">
                {audience.description}
              </p>

              <ul class="space-y-2.5">
                {audience.features.map((feature) => (
                  <li class="flex items-start gap-2.5 text-white/80">
                    <div class="w-4 h-4 rounded-full bg-primary/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <div class="w-1.5 h-1.5 bg-primary rounded-full"></div>
                    </div>
                    <span class="text-sm font-medium">{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Divider -->
    <div class="max-w-2xl mx-auto my-14">
      <div class="h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"></div>
    </div>

    <!-- CTA -->
    <div class="max-w-3xl mx-auto text-center scroll-animate">
      <h2 class="font-display text-2xl sm:text-3xl lg:text-4xl font-bold text-white mb-6 leading-[1.1] tracking-tight">
        La <span class="bg-gradient-to-r from-[#4CBFA6] to-[#3DAF8E] bg-clip-text text-transparent">última impermeabilización</span> que <br class="hidden sm:block" />
        va a necesitar.
      </h2>

      <p class="text-white/60 text-base md:text-lg mb-10 max-w-xl mx-auto leading-relaxed">
        Unimos tecnología de vanguardia y mano de obra experta para dar a su propiedad el blindaje que merece.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-5">
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative overflow-hidden rounded-md shadow-lg hover:shadow-[#25D366]/30 transition-all duration-500 bg-[#25D366] text-white px-6 py-3.5 lg:py-3 text-base font-medium inline-flex items-center justify-center"
        >
          <svg class="mr-2 h-5 w-5 relative z-10" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          <span class="relative z-10">Contactar por WhatsApp</span>
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/15 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-in-out"></div>
        </a>

        <a
          href="/contacto"
          class="group rounded-md border border-white/20 hover:border-white/40 backdrop-blur-sm transition-all duration-300 bg-white/10 hover:bg-white/15 text-white px-6 py-3.5 lg:py-3 text-base font-medium inline-flex items-center justify-center"
        >
          Agendar Diagnóstico
          <svg class="ml-2 h-4 w-4 opacity-60 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
      </div>
    </div>
  </div>

</section>

<script>
  function initForWhoTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('[data-forwho-tab]');
    const panels = document.querySelectorAll<HTMLDivElement>('[data-forwho-panel]');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const targetId = tab.dataset.forwhoTab;

        // Update tabs
        tabs.forEach((t) => {
          const isActive = t.dataset.forwhoTab === targetId;
          t.setAttribute('aria-selected', String(isActive));
          t.className = `group flex items-center gap-3 w-full text-left px-4 py-3 rounded-xl transition-all duration-500 ease-out border ${
            isActive
              ? 'bg-white/10 border-white/15 shadow-sm'
              : 'bg-transparent border-transparent hover:bg-white/5'
          }`;
          const h3 = t.querySelector('h3');
          if (h3) {
            h3.className = `font-display text-base font-semibold transition-colors duration-500 ${
              isActive ? 'text-white' : 'text-white/50 group-hover:text-white/80'
            }`;
          }
          const arrow = t.querySelector('[data-forwho-arrow]');
          if (arrow) {
            arrow.classList.toggle('hidden', !isActive);
          }
        });

        // Update panels
        panels.forEach((panel) => {
          const isActive = panel.dataset.forwhoPanel === targetId;
          panel.classList.toggle('hidden', !isActive);
          if (isActive) {
            const content = panel.querySelector('.animate-fade-up');
            if (content) {
              content.classList.remove('animate-fade-up');
              void (content as HTMLElement).offsetWidth;
              content.classList.add('animate-fade-up');
            }
          }
        });
      });
    });
  }

  initForWhoTabs();
  document.addEventListener('astro:page-load', initForWhoTabs);
</script>
