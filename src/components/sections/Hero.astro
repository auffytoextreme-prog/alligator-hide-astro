---
---

<section class="relative flex flex-col overflow-hidden bg-muted">
  <div class="relative min-h-screen flex items-center justify-center">
    <!-- Background Video -->
    <div class="absolute inset-0">
      <video
        autoplay
        muted
        loop
        playsinline
        poster="/hero-poster.webp"
        aria-hidden="true"
        role="presentation"
        class="w-full h-full object-cover"
      >
        <source src="/hero-video.mp4" type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-gradient-to-br from-secondary/80 via-secondary/70 to-primary/30"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 container mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-24">
      <div class="max-w-4xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-primary/20 backdrop-blur-sm text-primary-foreground px-4 py-2 rounded-full text-sm font-medium mb-10 animate-fade-up">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          Tecnología Elastomérica Importada de EE.UU.
        </div>

        <!-- Headline -->
        <h1 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl text-secondary-foreground leading-[1.1] mb-8 animate-fade-up" style="animation-delay: 100ms">
          Proteja su propiedad de la humedad y el calor con la Impermeabilización definitiva.
        </h1>

        <!-- Subheadline -->
        <p class="text-lg md:text-xl text-white/90 mb-12 max-w-2xl leading-relaxed animate-fade-up" style="animation-delay: 200ms">
          Elija tranquilidad y ahorro energético con el Sistema AlligatorHide, el más eficiente y resistente escudo para su techo. Con garantía de 18 años, diga adiós a las goteras y altas temperaturas.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 animate-fade-up" style="animation-delay: 300ms">
          <a
            href="/contacto"
            class="group relative overflow-hidden rounded-md shadow-lg hover:shadow-primary/30 transition-all duration-500 bg-primary text-primary-foreground px-6 py-3 text-base font-medium inline-flex items-center justify-center"
          >
            <span class="relative z-10">Solicitar Diagnóstico</span>
            <svg class="ml-2 h-4 w-4 transition-transform group-hover:translate-x-1 relative z-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/15 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-in-out"></div>
          </a>

          <a
            href="/tecnologia"
            class="group rounded-md border border-white/25 hover:border-white/50 backdrop-blur-sm transition-all duration-300 bg-white/5 hover:bg-white/10 text-white px-6 py-3 text-base font-medium inline-flex items-center justify-center"
          >
            Comprender el Sistema
            <svg class="ml-2 h-4 w-4 opacity-60 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce opacity-80 z-30">
      <span class="text-white/60 text-[10px] uppercase tracking-[0.25em] font-medium drop-shadow-md">Descubra más</span>
      <div class="w-[1px] h-8 bg-gradient-to-b from-white/60 to-transparent shadow-sm"></div>
    </div>
  </div>
</section>
