---
const badges = [
  {
    text: 'Garantía contractual por escrito',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
  },
  {
    text: 'Reflectancia Solar',
    icon: `<circle cx="12" cy="12" r="5" /><line x1="12" y1="1" x2="12" y2="3" /><line x1="12" y1="21" x2="12" y2="23" /><line x1="4.22" y1="4.22" x2="5.64" y2="5.64" /><line x1="18.36" y1="18.36" x2="19.78" y2="19.78" /><line x1="1" y1="12" x2="3" y2="12" /><line x1="21" y1="12" x2="23" y2="12" /><line x1="4.22" y1="19.78" x2="5.64" y2="18.36" /><line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />`,
  },
  {
    text: 'Productos ecológicos',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />`,
  },
  {
    text: 'Seguimiento técnico y mantenimiento',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />`,
  },
  {
    text: 'Fichas técnicas disponibles',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />`,
  },
];
---

<div class="bg-secondary py-5 relative overflow-hidden">
  <!-- Top accent line -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>

  <!-- Desktop: static centered row -->
  <div class="hidden lg:flex items-center justify-center gap-3 container mx-auto px-4 sm:px-6 lg:px-8">
    {badges.map((badge, i) => (
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-white/[0.06] border border-white/[0.08] backdrop-blur-sm hover:bg-white/[0.1] hover:border-accent/20 transition-all duration-300 flex-shrink-0">
          <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={badge.icon} />
          <span class="text-secondary-foreground/70 text-sm font-medium whitespace-nowrap">{badge.text}</span>
        </div>
        {i < badges.length - 1 && (
          <div class="w-1 h-1 rounded-full bg-secondary-foreground/20"></div>
        )}
      </div>
    ))}
  </div>

  <!-- Mobile: marquee -->
  <div class="lg:hidden">
    <div class="animate-marquee flex items-center gap-6">
      {badges.map((badge) => (
        <div class="flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-white/[0.06] border border-white/[0.08] backdrop-blur-sm hover:bg-white/[0.1] hover:border-accent/20 transition-all duration-300 flex-shrink-0">
          <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={badge.icon} />
          <span class="text-secondary-foreground/70 text-sm font-medium whitespace-nowrap">{badge.text}</span>
        </div>
      ))}
      {/* Duplicate for seamless loop */}
      {badges.map((badge) => (
        <div class="flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-white/[0.06] border border-white/[0.08] backdrop-blur-sm hover:bg-white/[0.1] hover:border-accent/20 transition-all duration-300 flex-shrink-0">
          <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={badge.icon} />
          <span class="text-secondary-foreground/70 text-sm font-medium whitespace-nowrap">{badge.text}</span>
        </div>
      ))}
    </div>
  </div>
</div>
