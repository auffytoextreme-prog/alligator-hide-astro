---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import img01 from '@/assets/gallery/preparacion-superficie.jpg';
import img02 from '@/assets/gallery/aplicacion-base-impermeabilizante.jpg';
import img03 from '@/assets/gallery/aplicacion-base-rodillo.jpg';
import img04 from '@/assets/gallery/sellado-de-canos.jpg';
import img05 from '@/assets/gallery/producto-alligatorhide.jpg';
import img06 from '@/assets/gallery/aplicacion-capa-blanca.jpg';
import img07 from '@/assets/gallery/techo-comercial-en-proceso.jpg';
import img08 from '@/assets/gallery/instalacion-tela-refuerzo.jpg';
import img09 from '@/assets/gallery/equipo-trabajo-en-terraza.jpg';
import img10 from '@/assets/gallery/aplicacion-rodillo-terraza.jpg';
import img11 from '@/assets/gallery/materiales-y-tela-refuerzo.jpg';
import img12 from '@/assets/gallery/capa-protectora-blanca.jpg';
import img13 from '@/assets/gallery/aplicacion-terraza-residencial.jpg';
import img14 from '@/assets/gallery/tecnico-alligatorhide.jpg';
import img15 from '@/assets/gallery/vista-aerea-antes.jpg';
import img16 from '@/assets/gallery/vista-aerea-antes-2.jpg';

import img18 from '@/assets/gallery/vista-aerea-antes-detalle.jpg';
import img19 from '@/assets/gallery/vista-aerea-proceso-parcial.jpg';
import img20 from '@/assets/gallery/vista-aerea-proceso-avance.jpg';
import img21 from '@/assets/gallery/vista-aerea-resultado-final.jpg';

import img23 from '@/assets/gallery/resultado-final-claraboyas.jpg';
import img26 from '@/assets/gallery/primer-alligatorhide.jpg';
import img27 from '@/assets/gallery/aplicacion-rodillo-primer.jpg';
import img28 from '@/assets/gallery/claraboyas-antes-tratamiento.jpg';

const galleryImages = [
  img01, img02, img03, img14, img26, img27, img09, img08, img11, img04, img05,
  img10, img12, img06, img13, img07, img28, img15, img16, img18,
  img19, img20, img21, img23,
];
---

<Layout
  title="Galería de Proyectos de Impermeabilización"
  description="Vea nuestros proyectos realizados: techos, terrazas, cubiertas industriales y más. Aplicación profesional del sistema AlligatorHide en Montevideo, Uruguay."
  canonical="/galeria"
>
  <!-- Hero Section -->
  <section class="pt-32 pb-14 relative overflow-hidden bg-[#0A1F16]">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0A1F16] via-[#153728] to-[#0A1F16]"></div>
      <div class="absolute bottom-0 left-0 w-1/4 h-full opacity-[0.04] pattern-crocodile"></div>
      <div class="absolute -top-20 right-1/4 w-[500px] h-[500px] bg-[#4CBFA6]/15 rounded-full blur-[150px] animate-pulse-subtle"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[350px] bg-[#4CBFA6]/10 rounded-full blur-[130px]"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[200px] bg-[#4CBFA6]/[0.04] rounded-full blur-[100px]"></div>
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-4xl">
        <h1 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-8 leading-[1.05] tracking-tight animate-fade-up">
          Galería de proyectos
        </h1>
        <p class="text-white/60 text-lg md:text-xl leading-relaxed max-w-3xl animate-fade-up" style="animation-delay: 100ms">
          Conozca algunos de nuestros trabajos realizados en techos, terrazas y otras superficies. Cada proyecto refleja nuestro compromiso con la excelencia.
        </p>
      </div>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="section-padding bg-background pb-0 relative overflow-hidden">
    <div class="absolute top-0 left-0 right-0 pointer-events-none z-10 leading-none -mt-px">
      <svg viewBox="0 0 1440 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-16 lg:h-24 block">
        <defs>
          <linearGradient id="gal-wave" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stop-color="#153728" />
            <stop offset="100%" stop-color="#0A1F16" />
          </linearGradient>
          <linearGradient id="gal-wave-fade" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#0A1F16" />
            <stop offset="100%" stop-color="hsl(0, 0%, 98%)" />
          </linearGradient>
        </defs>
        <path d="M0,0 L1440,0 L1440,100 L0,100 Z" fill="url(#gal-wave-fade)" />
        <path d="M0,40 C480,80 960,10 1440,50 L1440,0 L0,0 Z" fill="url(#gal-wave)" />
      </svg>
    </div>

    <div class="absolute inset-0 pointer-events-none opacity-[0.02]">
      <div class="absolute top-0 left-0 w-full h-full pattern-crocodile"></div>
    </div>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Main Preview -->
      <div class="max-w-5xl mx-auto mb-8">
        <div class="relative aspect-[16/9] overflow-hidden rounded-2xl ring-1 ring-foreground/10 shadow-2xl bg-foreground/5" id="gallery-preview-wrapper">
          {galleryImages.map((image, index) => (
            <Image
              src={image}
              alt={`Proyecto AlligatorHide ${index + 1}`}
              widths={[800, 1200, 1600]}
              sizes="(max-width: 1280px) 100vw, 1120px"
              format="webp"
              loading={index === 0 ? 'eager' : 'lazy'}
              decoding="async"
              class={`absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ${index === 0 ? 'opacity-100' : 'opacity-0 pointer-events-none'}`}
              data-preview-img={index}
            />
          ))}
          <!-- Nav arrows -->
          <button
            id="preview-prev"
            class="absolute left-4 top-1/2 -translate-y-1/2 z-10 w-11 h-11 bg-black/30 backdrop-blur-md text-white hover:bg-black/50 transition-colors rounded-full flex items-center justify-center border border-white/10"
            aria-label="Anterior"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6" /></svg>
          </button>
          <button
            id="preview-next"
            class="absolute right-4 top-1/2 -translate-y-1/2 z-10 w-11 h-11 bg-black/30 backdrop-blur-md text-white hover:bg-black/50 transition-colors rounded-full flex items-center justify-center border border-white/10"
            aria-label="Siguiente"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>
          </button>
          <!-- Counter -->
          <div class="absolute bottom-4 right-4 z-10 bg-black/40 backdrop-blur-md text-white/70 text-xs font-medium px-3 py-1.5 rounded-full border border-white/10" id="preview-counter">
            1 / {galleryImages.length}
          </div>
        </div>
      </div>

      <!-- Thumbnails -->
      <div class="max-w-5xl mx-auto">
        <div class="flex gap-3 overflow-x-auto pb-4 scrollbar-thin" id="gallery-thumbs">
          {galleryImages.map((image, index) => (
            <button
              class={`relative flex-shrink-0 w-20 h-16 sm:w-24 sm:h-[72px] overflow-hidden rounded-xl cursor-pointer transition-all duration-300 ${index === 0 ? 'ring-2 ring-[#4CBFA6] shadow-lg shadow-[#4CBFA6]/20 opacity-100' : 'ring-1 ring-foreground/10 opacity-50 hover:opacity-80'}`}
              data-thumb={index}
              aria-selected={index === 0 ? 'true' : 'false'}
            >
              <Image
                src={image}
                alt={`Miniatura ${index + 1}`}
                widths={[100, 150]}
                sizes="96px"
                format="webp"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover"
              />
            </button>
          ))}
        </div>
      </div>
    </div>

    <!-- Separador decorativo -->
    <div class="mt-20 mb-0">
      <svg viewBox="0 0 1440 180" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-28 lg:h-40 block">
        <path d="M0,90 C360,150 720,20 1080,100 C1260,135 1380,90 1440,90 L1440,180 L0,180 Z" fill="#0A1F16" />
      </svg>
    </div>
  </section>

</Layout>

<script>
  function initGallery() {
    const previewImgs = document.querySelectorAll<HTMLElement>('[data-preview-img]');
    const thumbs = document.querySelectorAll<HTMLElement>('[data-thumb]');
    const counter = document.getElementById('preview-counter');
    const prevBtn = document.getElementById('preview-prev');
    const nextBtn = document.getElementById('preview-next');
    const thumbsContainer = document.getElementById('gallery-thumbs');

    if (!previewImgs.length) return;

    let current = 0;
    const total = previewImgs.length;

    function activate(index: number) {
      previewImgs.forEach((img, i) => {
        img.classList.toggle('opacity-100', i === index);
        img.classList.toggle('opacity-0', i !== index);
        img.classList.toggle('pointer-events-none', i !== index);
      });

      thumbs.forEach((thumb, i) => {
        if (i === index) {
          thumb.className = thumb.className
            .replace('ring-1 ring-foreground/10 opacity-50 hover:opacity-80', 'ring-2 ring-[#4CBFA6] shadow-lg shadow-[#4CBFA6]/20 opacity-100');
        } else {
          thumb.className = thumb.className
            .replace('ring-2 ring-[#4CBFA6] shadow-lg shadow-[#4CBFA6]/20 opacity-100', 'ring-1 ring-foreground/10 opacity-50 hover:opacity-80');
        }
      });

      if (counter) counter.textContent = `${index + 1} / ${total}`;
      current = index;

      // Scroll active thumb into view
      const activeThumb = thumbs[index] as HTMLElement;
      if (activeThumb && thumbsContainer) {
        activeThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      }
    }

    thumbs.forEach(thumb => {
      thumb.addEventListener('click', () => {
        const index = parseInt(thumb.dataset.thumb || '0', 10);
        activate(index);
      });
    });

    prevBtn?.addEventListener('click', () => activate((current - 1 + total) % total));
    nextBtn?.addEventListener('click', () => activate((current + 1) % total));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') activate((current + 1) % total);
      if (e.key === 'ArrowLeft') activate((current - 1 + total) % total);
    });
  }

  initGallery();
  document.addEventListener('astro:page-load', initGallery);
</script>
